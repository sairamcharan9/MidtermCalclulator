# ============================================================
# Calculator Application — Configuration Template
# Copy this file to .env and adjust values as needed.
# ============================================================

# -- Base Directories ----------------------------------------
# Directory where log files are written
CALCULATOR_LOG_DIR=logs

# Name of the log file inside CALCULATOR_LOG_DIR
CALCULATOR_LOG_FILE=calculator.log

# Directory where history CSV files are stored
CALCULATOR_HISTORY_DIR=data

# Name of the history CSV file inside CALCULATOR_HISTORY_DIR
CALCULATOR_HISTORY_FILE=history.csv

# -- History Settings ----------------------------------------
# Maximum number of calculation history entries to keep (positive integer)
CALCULATOR_MAX_HISTORY_SIZE=1000

# Whether to auto-save history to CSV after every calculation (true | false)
CALCULATOR_AUTO_SAVE=true

# -- Calculation Settings ------------------------------------
# Number of decimal places for calculation results (0–20)
CALCULATOR_PRECISION=2

# Maximum allowed absolute input value
CALCULATOR_MAX_INPUT_VALUE=1e10

# Default file encoding (utf-8 | utf-16 | utf-32 | ascii | latin-1 | iso-8859-1)
CALCULATOR_DEFAULT_ENCODING=utf-8

# -- JWT Authentication Configuration -----------------------
# Secret key used to sign JWT tokens (use a long random string in production)
JWT_SECRET=change-me-to-a-long-random-string-in-production

# JWT signing algorithm (HS256 recommended)
JWT_ALGORITHM=HS256

# Token expiry in minutes (30 minutes default)
JWT_EXPIRE_MINUTES=30

